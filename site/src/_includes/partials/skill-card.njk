<article class="skill-card">
  <span class="skill-card__category" aria-label="Category">{{ categoryLabels[skill.category] or skill.category }}</span>
  <h3 class="skill-card__title">
    <a href="{{ ('/' ~ lang ~ '/skills/' ~ skill.slug ~ '/') | url }}">{{ skill.displayName }}</a>
  </h3>
  <p class="skill-card__description">{{ skill.description }}</p>
  <footer class="skill-card__footer">
    <div class="skill-card__installs" aria-label="Install command">
      {% for method in installMethods.methods %}
        <code class="skill-card__install install--{{ method.id }}" id="install-{{ method.id }}-{{ skill.slug }}">{{ skill.installCommands[method.id] }}</code>
      {% endfor %}
      <button type="button" class="copy-btn"
              data-copy-active-install
              data-copied-label="{{ t.ui.copyCopied }}"
              aria-label="{{ t.skill.copyInstall }} {{ skill.slug }}">{{ t.ui.copyShort }}</button>
    </div>
    <a class="skill-card__more-install" href="{{ ('/' ~ lang ~ '/skills/' ~ skill.slug ~ '/#install') | url }}">{{ t.ui.moreInstallMethods }} →</a>
  </footer>
</article>
