{% macro installBlock(id, command, copyLabel) %}
<div class="install-block">
  <pre class="install-block__code" id="{{ id }}"><code>{{ command }}</code></pre>
  <button type="button" class="copy-btn copy-btn--lg" data-copy-target="{{ id }}" aria-label="{{ copyLabel }}">
    <span class="copy-btn__label">{{ copyLabel }}</span>
  </button>
</div>
{% endmacro %}
