---
permalink: /de/search-index.json
eleventyExcludeFromCollections: true
---
{%- set records = [] -%}
{%- for skill in skills -%}
  {%- set entry = {
    slug: skill.slug,
    name: skill.displayName,
    desc: skill.descriptionDe,
    category: skill.categoryLabelDe,
    categorySlug: skill.category,
    group: skill.group,
    tags: skill.tags,
    useCases: skill.useCases,
    url: ('/de/skills/' ~ skill.slug ~ '/') | url
  } -%}
  {%- set records = (records.push(entry), records) -%}
{%- endfor -%}
{{ records | dump | safe }}
